  "update-gateway-status": {
    "url": "/gateways/mobile-money/update",
    "method": "POST",
    "description": "Update status for a mobile money gateway. Marks current message as historical and inserts new current message.",
    "authentication": "Required (API Key or Service Token)",
    
    "request_body": {
      "telecom": "M-Pesa KE",
      "api_status": "OK",
      "message": "success 98.9% • p95 9.2s"
    },
    
    "required_fields": ["telecom", "api_status"],
    "optional_fields": ["message"],
    
    "response_format": {
      "status": "success",
      "message": "Status updated for gateway 'M-Pesa KE'",
      "data": {
        "id": 124,
        "telecom": "M-Pesa KE",
        "api_status": "OK",
        "message": "success 98.9% • p95 9.2s",
        "created_at": "2026-03-04T15:40:00.123456"
      }
    },
    
    "behavior": {
      "description": "This endpoint performs two operations atomically",
      "steps": [
        "1. UPDATE existing record: SET is_current_message = FALSE WHERE telecom = {telecom} AND is_current_message = TRUE",
        "2. INSERT new record: (telecom, api_status, message, is_current_message=TRUE)"
      ]
    },
    
    "monitoring_integration": {
      "description": "Call this endpoint to update gateway status from monitoring service",
      "usage": "POST new status whenever gateway health changes",
      "example_curl": "curl -X POST http://api/gateways/mobile-money/update -H 'Content-Type: application/json' -d '{\"telecom\":\"M-Pesa KE\",\"api_status\":\"OK\",\"message\":\"success 98.9% • p95 9.2s\"}'"
    }
  },
  
  "message_format_examples": {
    "description": "Common message format patterns for the 'message' field",
    "examples": [
      "success 98.9% • p95 9.2s",
      "success 97.6% • p95 11.4s",
      "success 91.2% • webhook fail 6.7%",
      "success 96.8% • settle delay 18m",
      "DOWN • timeout after 30s",
      "MAINTENANCE • scheduled until 16:00"
    ],
    "formatting_rules": [
      "Use bullet point separator: •",
      "Include success rate if available",
      "Include p95 latency if available",
      "Mention specific issues (webhook fail, settle delay, etc.)",
      "Keep concise for frontend display"
    ]
  }
}
