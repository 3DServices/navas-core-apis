# ============================================================
# NAVAS Core APIs — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
#
# Required variables (app will not start without these):
# ------------------------------------------------------------

DATABASE_URL=postgresql://user:password@host:5432/database_name
JWT_SECRET=replace-with-a-strong-random-secret-at-least-64-chars

# Optional variables (safe defaults are used if omitted):
# ------------------------------------------------------------

# BASE_URL=https://narvas.3dservices.co.ug/
# JWT_ACCESS_EXPIRY_MINUTES=30
# JWT_REFRESH_EXPIRY_DAYS=7
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://narvas.3dservices.co.ug,https://cms.3dservices.net
